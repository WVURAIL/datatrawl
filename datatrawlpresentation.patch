+\usetikzlibrary{arrows.meta,positioning,calc,fit,shapes.geometric,decorations.pathreplacing}
+\pagecolor{white}
+\input{datatrawl-figures.sty}
+\begin{document}
+\input{fig-plugin-ecosystem.tikz}
+\end{document}
